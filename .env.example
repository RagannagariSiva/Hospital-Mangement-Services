# ============================================================
# Hotel Platform - Environment Configuration
# Copy this file to .env and update values
# ============================================================

# Database
DB_USERNAME=root
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hotel_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (change in production - must be at least 64 chars)
JWT_SECRET=hotelPlatformSuperSecretKeyForJWTTokenGeneration2024XYZ_ChangeThis

# Email (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Razorpay (optional - for real payments)
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Frontend
REACT_APP_API_URL=http://localhost:8080/api
